# Nginx Configuration for COGURA (Static Export)

server {
    listen 80;
    server_name cogura.store;
    return 301 https://www.cogura.store$request_uri;
}

server {
    listen 443 ssl http2;
    server_name cogura.store;
    
    # SSL Configuration (Use your certs)
    # ssl_certificate /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    # Canonical Redirect (non-www to www)
    # Or vice versa, depending on preference. Here we redirect non-www to www.
    return 301 https://www.cogura.store$request_uri;
}

server {
    listen 443 ssl http2;
    server_name www.cogura.store;

    root /var/www/cogura/out;
    index index.html;

    # Security Headers
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options "DENY" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Static Assets Caching (Images)
    location ~* \.(webp|avif|ico|png|jpg|jpeg|svg)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Next.js Static Assets
    location /_next/static/ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Handle 404
    error_page 404 /404.html;
    location = /404.html {
        internal;
    }

    location / {
        try_files $uri $uri.html $uri/ =404;
    }
}
